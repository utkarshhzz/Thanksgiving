# Frontend Environment Variables
# Copy this file to .env and fill in the values
# IMPORTANT: All Vite env vars must start with VITE_ to be accessible in browser code

# ── Backend API URL ───────────────────────────────────────────────────────────
# Development: your local FastAPI server
VITE_API_URL=http://localhost:8000/api/v1

# Production (fill in after deploying backend to Render):
# VITE_API_URL=https://thanksgiving-api.onrender.com/api/v1

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Get this from https://console.cloud.google.com/
# Create OAuth 2.0 credentials → Web Application
# Add Authorized Origins: http://localhost:5173 (dev) + your Render URL (prod)
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
