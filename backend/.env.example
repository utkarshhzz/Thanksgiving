# Application
APP_NAME=ThankGiving API
APP_ENV=development
APP_VERSION=1.0.0
DEBUG=true

# Security - CHANGE THESE IN PRODUCTION
SECRET_KEY=your-super-secret-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=90
ALGORITHM=HS256

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://username:password@localhost:5432/thanksgiving_db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# CORS - Frontend URL
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Cloudinary — image uploads (free at cloudinary.com)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email — Resend (free 100/day at resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxx

# Email — Brevo/Sendinblue (free 300/day at brevo.com → Settings → API Keys)
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxx

# AI — Google Gemini (free tier, get key at aistudio.google.com → Get API Key)
# Powers: campaign copy improvement, similar suggestions, impact summary
GEMINI_API_KEY=AIzaSy-xxxxxxxxxxxxxxxxxxxx

# Payments — Razorpay (free test keys at razorpay.com > Settings > API Keys)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
