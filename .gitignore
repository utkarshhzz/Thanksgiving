# ── Agent files ───────────────────────────────────────────────────────────────
*.agent
.agent*

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
venv/
.venv/
env/
*.egg-info/
dist/
build/
.eggs/

# ── Environment variables (NEVER commit these — contain secrets) ───────────────
.env
.env.*
.env.local
.env.test
.env.production
.env.*.local
backend/.env
backend/.env.*
frontend/.env
frontend/.env.*
frontend/.env.local
**/.env           # catch .env in any subdirectory
**/.env.*         # catch .env.test, .env.local etc in any subdirectory

# ── Node / Frontend ───────────────────────────────────────────────────────────
node_modules/
frontend/dist/
frontend/build/
*.tsbuildinfo

# ── Database / Alembic cache ──────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Docs (internal) ───────────────────────────────────────────────────────────
docs/